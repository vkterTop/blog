---
interface Props {
  name: string;
  slug: string;
  count: number;
  keywords?: string[];
}

const { name, slug, count, keywords = [] } = Astro.props;
const keywordPreview = keywords.slice(0, 3).join(' · ');
---

<a
  href={`/${slug}/`}
  class="group relative block p-5 md:p-6 bg-paper-muted border border-paper-dark transition-all duration-300 hover:-translate-y-1 hover:bg-paper-accent hover:border-paper-dark/80"
>
  <div class="flex flex-col gap-2">
    <h3 class="font-serif text-xl md:text-2xl font-semibold text-ink group-hover:text-vermilion transition-colors">
      {name}
    </h3>
    <p class="text-sm text-ink-soft">
      {count} 篇文章
    </p>
    {keywordPreview && (
      <p class="text-xs text-ink-muted line-clamp-1">{keywordPreview}</p>
    )}
  </div>
  <span class="absolute right-4 top-1/2 -translate-y-1/2 text-2xl text-ink-muted group-hover:text-vermilion transition-colors">→</span>
</a>
