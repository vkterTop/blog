---
import { getCategorySlug } from '../utils/pinyin.js';

const navLinks = [
  { label: '首页', href: '/' },
  { label: '专栏', href: '/zhuanlan/' },
  { label: '归档', href: '/archive/' },
  { label: '搜索', href: '/search/' },
];

const { pathname } = Astro.url;
---

<header class="sticky top-0 z-40 h-14 md:h-16 border-b border-paper-dark bg-paper/85 backdrop-blur-md">
  <nav class="mx-auto flex h-full max-w-7xl items-center justify-between px-4 md:px-6 lg:px-8">
    <a href="/" class="flex items-center gap-2 text-ink no-underline">
      <span class="font-seal text-2xl text-vermilion">皇汉</span>
      <span class="font-serif text-lg md:text-xl font-semibold tracking-wide">学堂</span>
    </a>

    <div class="hidden md:flex items-center gap-8">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class={`font-body text-base transition-colors duration-200 ${
            pathname === link.href
              ? 'text-vermilion'
              : 'text-ink-soft hover:text-ink'
          }`}
        >
          {link.label}
        </a>
      ))}
    </div>

    <div class="flex items-center gap-3">
      <button
        id="theme-toggle"
        type="button"
        aria-label="切换深色模式"
        class="p-2 rounded-sm text-ink-soft hover:text-ink hover:bg-paper-muted transition-colors"
      >
        <svg id="theme-icon-sun" class="w-5 h-5 hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="4" />
          <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41" />
        </svg>
        <svg id="theme-icon-moon" class="w-5 h-5 hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
        </svg>
      </button>

      <button
        id="mobile-menu-button"
        type="button"
        aria-label="打开菜单"
        class="md:hidden p-2 rounded-sm text-ink-soft hover:text-ink hover:bg-paper-muted transition-colors"
      >
        <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <line x1="3" y1="6" x2="21" y2="6" />
          <line x1="3" y1="12" x2="21" y2="12" />
          <line x1="3" y1="18" x2="21" y2="18" />
        </svg>
      </button>
    </div>
  </nav>
</header>

<script is:inline>
  (function () {
    const toggle = document.getElementById('theme-toggle');
    const sun = document.getElementById('theme-icon-sun');
    const moon = document.getElementById('theme-icon-moon');
    const html = document.documentElement;

    function updateIcon() {
      if (html.classList.contains('dark')) {
        sun.classList.remove('hidden');
        moon.classList.add('hidden');
      } else {
        sun.classList.add('hidden');
        moon.classList.remove('hidden');
      }
    }

    updateIcon();

    toggle.addEventListener('click', function () {
      if (html.classList.contains('dark')) {
        html.classList.remove('dark');
        localStorage.setItem('theme', 'light');
      } else {
        html.classList.add('dark');
        localStorage.setItem('theme', 'dark');
      }
      updateIcon();
    });
  })();
</script>
