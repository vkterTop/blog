---
interface Props {
  currentPage: number;
  totalPages: number;
  baseUrl: string;
}

const { currentPage, totalPages, baseUrl } = Astro.props;

function pageUrl(page: number) {
  return page === 1 ? baseUrl : `${baseUrl}page/${page}/`;
}

/**
 * 生成截断分页项
 * 规则：
 * - 总页数 <= 7 时全部展示
 * - 否则始终展示首页、尾页、当前页及相邻页
 * - 间隙以省略号填充，保证移动端不溢出
 */
function getPageItems(current: number, total: number) {
  const items: Array<{ type: 'page'; page: number } | { type: 'ellipsis' }> = [];

  if (total <= 7) {
    for (let i = 1; i <= total; i++) {
      items.push({ type: 'page', page: i });
    }
    return items;
  }

  // 左侧：首页 + 省略号或次页
  if (current <= 3) {
    for (let i = 1; i <= Math.max(4, current + 1); i++) {
      items.push({ type: 'page', page: i });
    }
    if (current + 1 < total - 1) {
      items.push({ type: 'ellipsis' });
    }
    items.push({ type: 'page', page: total });
    return items;
  }

  // 右侧：尾页 + 省略号或次尾页
  if (current >= total - 2) {
    items.push({ type: 'page', page: 1 });
    if (current - 1 > 2) {
      items.push({ type: 'ellipsis' });
    }
    for (let i = Math.min(current - 1, total - 3); i <= total; i++) {
      items.push({ type: 'page', page: i });
    }
    return items;
  }

  // 中间：首页 ... 当前-1 当前 当前+1 ... 尾页
  items.push({ type: 'page', page: 1 });
  if (current - 2 > 1) {
    items.push({ type: 'ellipsis' });
  } else if (current - 2 === 1) {
    items.push({ type: 'page', page: 2 });
  }

  for (let i = current - 1; i <= current + 1; i++) {
    items.push({ type: 'page', page: i });
  }

  if (current + 2 < total) {
    items.push({ type: 'ellipsis' });
  } else if (current + 2 === total) {
    items.push({ type: 'page', page: total - 1 });
  }
  items.push({ type: 'page', page: total });

  return items;
}

const pageItems = getPageItems(currentPage, totalPages);
---

{totalPages > 1 && (
  <nav aria-label="分页" class="flex flex-wrap items-center justify-center gap-2 sm:gap-3 mt-12">
    {currentPage > 1 && (
      <a
        href={pageUrl(currentPage - 1)}
        class="px-2 sm:px-3 py-1.5 text-sm border border-paper-dark text-ink-soft hover:text-ink hover:bg-paper-muted transition-colors"
      >
        上一页
      </a>
    )}

    <div class="flex items-center gap-1 sm:gap-2">
      {pageItems.map((item) => (
        item.type === 'ellipsis' ? (
          <span class="w-8 h-8 flex items-center justify-center text-sm text-ink-muted">…</span>
        ) : item.page === currentPage ? (
          <span
            class="w-8 h-8 flex items-center justify-center rounded-full bg-vermilion text-white text-sm font-medium"
            aria-current="page"
          >
            {item.page}
          </span>
        ) : (
          <a
            href={pageUrl(item.page)}
            class="w-8 h-8 flex items-center justify-center rounded-full text-sm text-ink-soft hover:text-ink hover:bg-paper-muted transition-colors"
          >
            {item.page}
          </a>
        )
      ))}
    </div>

    {currentPage < totalPages && (
      <a
        href={pageUrl(currentPage + 1)}
        class="px-2 sm:px-3 py-1.5 text-sm border border-paper-dark text-ink-soft hover:text-ink hover:bg-paper-muted transition-colors"
      >
        下一页
      </a>
    )}
  </nav>
)}
