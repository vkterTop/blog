---
import BaseLayout from './BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import ScrollToTop from '../components/ScrollToTop.astro';
import TableOfContents from '../components/TableOfContents.astro';
import MobileMenu from '../components/MobileMenu.astro';
import { format } from '../utils/date.js';
import { getColumnBySlug } from '../utils/columns.js';
import { getCategoryUrlPath } from '../utils/slug.js';
import { withBase } from '../utils/path.js';

interface Props {
  title: string;
  description?: string;
  category: string;
  categorySlug: string;
  columnSlug: string;
  pubDate?: Date;
  keywords?: string[];
  headings: any[];
  prev?: { slug: string; title: string };
  next?: { slug: string; title: string };
}

const { title, description, category, categorySlug, columnSlug, pubDate, keywords = [], headings, prev, next } = Astro.props;
const columnName = getColumnBySlug(columnSlug).name;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site || 'https://huanghanxuetang.example.com').toString();
---

<BaseLayout title={title} description={description} type="article" canonicalUrl={canonicalUrl}>
  <Navbar slot="header" />
  <MobileMenu slot="header" />

  <main slot="main" class="flex-1">
    <article class="mx-auto max-w-7xl px-4 py-8 md:px-6 lg:px-8 lg:py-12">
      <div class="grid grid-cols-1 lg:grid-cols-[minmax(0,1fr)_220px] gap-10 lg:gap-16">
        <div>
          <header class="mb-10 md:mb-14 text-center border-b border-paper-dark pb-8 md:pb-10">
            <div class="flex flex-wrap items-center justify-center gap-3 mb-5 text-sm">
              <a href={withBase('/zhuanlan/')} class="text-ink-muted hover:text-vermilion">专栏</a>
              <span class="text-ink-muted">/</span>
              <a href={withBase(`/zhuanlan/${columnSlug}/`)} class="text-ink-muted hover:text-vermilion">{columnName}</a>
              <span class="text-ink-muted">/</span>
              <a href={getCategoryUrlPath(categorySlug, columnSlug)} class="text-vermilion font-medium hover:text-vermilion-hover">{category}</a>
              <span class="text-ink-muted">/</span>
              {pubDate && <span class="text-ink-muted">{format(pubDate)}</span>}
            </div>
            <h1 class="font-serif text-2xl md:text-3xl lg:text-[2.5rem] font-semibold leading-snug text-ink max-w-3xl mx-auto">
              {title}
            </h1>
            <div class="mt-6 flex items-center justify-center gap-2 text-ink-muted text-xs tracking-widest">
              <span class="w-6 h-px bg-paper-dark"></span>
              <span>素笺墨韵</span>
              <span class="w-6 h-px bg-paper-dark"></span>
            </div>
            {keywords.length > 0 && (
              <div class="flex flex-wrap justify-center gap-2 mt-6">
                {keywords.map((k) => (
                  <span class="px-2 py-1 text-xs border border-paper-dark rounded-sm text-ink-soft bg-paper-muted">
                    {k}
                  </span>
                ))}
              </div>
            )}
          </header>

          <div class="prose-chinese">
            <slot />
          </div>

          <footer class="mt-16 pt-8 border-t border-paper-dark">
            {columnSlug === 'chigua-mengzhu' && (
              <div class="mb-6 p-4 bg-paper-muted border border-paper-dark text-sm text-ink-soft leading-relaxed">
                <p class="font-medium text-ink mb-1">声明</p>
                <p>本文内容源自“吃瓜蒙主”网络录播视频，经语音识别与 AI 整理后生成，仅供学习交流之用。若侵犯相关权利人权益，请联系站长删除。</p>
              </div>
            )}
            <div class="flex flex-col md:flex-row justify-between gap-6">
              {prev && (
                <a href={prev.slug} class="group flex-1 p-4 bg-paper-muted border border-paper-dark hover:border-paper-dark/80 transition-colors">
                  <span class="text-xs text-ink-muted block mb-1">上一篇</span>
                  <span class="font-serif text-base text-ink group-hover:text-vermilion transition-colors line-clamp-2">{prev.title}</span>
                </a>
              )}
              {next && (
                <a href={next.slug} class="group flex-1 p-4 bg-paper-muted border border-paper-dark hover:border-paper-dark/80 transition-colors text-right">
                  <span class="text-xs text-ink-muted block mb-1">下一篇</span>
                  <span class="font-serif text-base text-ink group-hover:text-vermilion transition-colors line-clamp-2">{next.title}</span>
                </a>
              )}
            </div>
          </footer>
        </div>

        <aside class="hidden lg:block">
          <TableOfContents headings={headings} />
        </aside>
      </div>
    </article>
  </main>

  <Footer slot="footer" />
  <ScrollToTop />
</BaseLayout>
