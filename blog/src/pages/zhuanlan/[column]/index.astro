---
import { getCollection } from 'astro:content';
import { categorySlugs, getCategoryLabel } from '../../../utils/pinyin.js';
import { getColumnBySlug, getColumnSlug } from '../../../utils/columns.js';
import { getPostUrlPath, getCategoryUrlPath } from '../../../utils/slug.js';
import { withBase } from '../../../utils/path.js';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Navbar from '../../../components/Navbar.astro';
import MobileMenu from '../../../components/MobileMenu.astro';
import Footer from '../../../components/Footer.astro';
import ScrollToTop from '../../../components/ScrollToTop.astro';
import CategoryCard from '../../../components/CategoryCard.astro';
import PostCard from '../../../components/PostCard.astro';

export async function getStaticPaths() {
  const { columns } = await import('../../../utils/columns.js');
  return columns.map((col) => ({ params: { column: col.slug } }));
}

const { column } = Astro.params;
const columnInfo = getColumnBySlug(column);
const allPosts = await getCollection('posts');
const columnPosts = allPosts.filter((p) => getColumnSlug(p.data.column) === column);

const sortedPosts = columnPosts.sort((a, b) => {
  const da = a.data.pubDate ? new Date(a.data.pubDate).getTime() : 0;
  const db = b.data.pubDate ? new Date(b.data.pubDate).getTime() : 0;
  return db - da;
});

const latestPosts = sortedPosts.slice(0, 8);

const categoryEntries = Object.entries(categorySlugs).map(([name, slug]) => {
  const count = columnPosts.filter((p) => p.slug.startsWith(`${slug}-`)).length;
  const sample = columnPosts.find((p) => p.slug.startsWith(`${slug}-`));
  const keywords = sample?.data?.keywords?.slice(0, 3) || [name];
  return { name, slug, count, keywords };
}).filter((c) => c.count > 0);
---

<BaseLayout title={`${columnInfo.name} - 专栏`} description={`${columnInfo.description}`}>
  <Navbar slot="header" />
  <MobileMenu slot="header" />

  <main slot="main" class="flex-1">
    <div class="mx-auto max-w-7xl px-4 py-12 md:px-6 lg:px-8 lg:py-16">
      <header class="mb-10 border-b border-paper-dark pb-6">
        <div class="text-sm text-ink-muted mb-2">
          <a href={withBase('/zhuanlan/')} class="hover:text-vermilion">专栏</a>
          <span class="mx-2">/</span>
          <span class="text-ink-soft">{columnInfo.name}</span>
        </div>
        <h1 class="font-serif text-3xl md:text-4xl font-semibold text-ink">{columnInfo.name}</h1>
        <p class="mt-2 text-ink-soft">{columnInfo.description}</p>
        <p class="mt-2 text-sm text-ink-muted">共 {columnPosts.length} 篇文章，{categoryEntries.length} 个分类。</p>
      </header>

      {column === 'chigua-mengzhu' && (
        <section class="mb-10 p-5 md:p-6 bg-paper-muted border border-paper-dark rounded-sm">
          <h2 class="font-serif text-lg font-semibold text-ink mb-3">声明</h2>
          <div class="text-sm text-ink-soft leading-relaxed space-y-2">
            <p>
              本专栏内容源自“吃瓜蒙主”网络录播视频，经语音识别与 AI 整理后生成，仅供学习交流之用。
            </p>
            <p>
              若相关内容侵犯原作者、主播或权利人权益，请联系站长处理，本站将在核实后第一时间删除。
            </p>
          </div>
        </section>
      )}

      <section class="mb-12">
        <h2 class="font-serif text-2xl md:text-3xl font-semibold text-ink mb-6">分类</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          {categoryEntries.map((c) => (
            <CategoryCard
              name={c.name}
              slug={getCategoryUrlPath(c.slug, column)}
              count={c.count}
              keywords={c.keywords}
            />
          ))}
        </div>
      </section>

      <section>
        <div class="flex items-center justify-between mb-6">
          <h2 class="font-serif text-2xl md:text-3xl font-semibold text-ink">最新文章</h2>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
          {latestPosts.map((post) => (
            <PostCard post={{ ...post, slug: getPostUrlPath(post) }} />
          ))}
        </div>
      </section>
    </div>
  </main>

  <Footer slot="footer" />
  <ScrollToTop />
</BaseLayout>
